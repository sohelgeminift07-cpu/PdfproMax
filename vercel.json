{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/gemini/:model/generateContent",
      "destination": "/api/gemini?model=:model"
    }
  ],
  "functions": {
    "api/gemini.js": {
      "maxDuration": 60
    },
    "api/gemini-ws-token.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/icon-(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
