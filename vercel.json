{
  "version": 2,
  "routes": [
    { "src": "/api/gemini-ws-token", "dest": "/api/gemini-ws-token.js" },
    { "src": "/api/gemini/(.+)/generateContent", "dest": "/api/gemini/[model].js" },
    { "src": "/api/groq", "dest": "/api/groq.js" },
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
