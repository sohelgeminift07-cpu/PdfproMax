# ── MaxOfPdf Vercel Environment Variables ──
# Add these in your Vercel project Dashboard → Settings → Environment Variables
# Do NOT commit real keys to git. Use .env locally and Vercel UI for production.

# Gemini API keys (comma-separated for rotation, or use individual keys)
GEMINI_KEYS=your_first_gemini_key_here,another_key_here
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=

# Groq API key (used for qwen, kimi, etc.)
GROQ_API_KEY=your_groq_key_here

# Groq Maverick key (used for llama-4-maverick model)
MAVERICK_KEY=your_maverick_key_here

# Optional: Node environment (Vercel sets this automatically)
# NODE_ENV=production
